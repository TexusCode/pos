<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PosDesktop.ViewModels"
        xmlns:svg="clr-namespace:Avalonia.Svg.Skia;assembly=Avalonia.Svg.Skia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1420"
        d:DesignHeight="900"
        x:Class="PosDesktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="TexHub POS Desktop"
        Width="1420"
        Height="900"
        MinWidth="1180"
        MinHeight="760"
        Background="#F1F5F9">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="Meta+Shift+S" Command="{Binding ToggleCloseShiftDialogCommand}" />
        <KeyBinding Gesture="Control+Shift+S" Command="{Binding ToggleCloseShiftDialogCommand}" />

        <KeyBinding Gesture="Meta+R" Command="{Binding RefreshAllCommand}" />
        <KeyBinding Gesture="Control+R" Command="{Binding RefreshAllCommand}" />

        <KeyBinding Gesture="Meta+Shift+Q" Command="{Binding LogoutCommand}" />
        <KeyBinding Gesture="Control+Shift+Q" Command="{Binding LogoutCommand}" />

        <KeyBinding Gesture="Meta+Shift+P" Command="{Binding TogglePayDebtDialogCommand}" />
        <KeyBinding Gesture="Control+Shift+P" Command="{Binding TogglePayDebtDialogCommand}" />
        <KeyBinding Gesture="Meta+Shift+A" Command="{Binding ToggleAddProductDialogCommand}" />
        <KeyBinding Gesture="Control+Shift+A" Command="{Binding ToggleAddProductDialogCommand}" />
        <KeyBinding Gesture="Meta+Shift+E" Command="{Binding ToggleAddExpenseDialogCommand}" />
        <KeyBinding Gesture="Control+Shift+E" Command="{Binding ToggleAddExpenseDialogCommand}" />

        <KeyBinding Gesture="Meta+M" Command="{Binding ToggleDiscountDialogCommand}" />
        <KeyBinding Gesture="Control+M" Command="{Binding ToggleDiscountDialogCommand}" />
        <KeyBinding Gesture="Meta+Shift+M" Command="{Binding ApplyDiscountCommand}" />
        <KeyBinding Gesture="Control+Shift+M" Command="{Binding ApplyDiscountCommand}" />
        <KeyBinding Gesture="Meta+Shift+D" Command="{Binding ApplyItemDiscountCommand}" />
        <KeyBinding Gesture="Control+Shift+D" Command="{Binding ApplyItemDiscountCommand}" />
        <KeyBinding Gesture="Escape" Command="{Binding CloseOpenDialogCommand}" />

        <KeyBinding Gesture="Meta+Enter" Command="{Binding ToggleCheckoutDialogCommand}" />
        <KeyBinding Gesture="Control+Enter" Command="{Binding ToggleCheckoutDialogCommand}" />
        <KeyBinding Gesture="Meta+Shift+Enter" Command="{Binding CheckoutCommand}" />
        <KeyBinding Gesture="Control+Shift+Enter" Command="{Binding CheckoutCommand}" />

        <KeyBinding Gesture="Meta+X" Command="{Binding HoldCartCommand}" />
        <KeyBinding Gesture="Control+X" Command="{Binding HoldCartCommand}" />

        <KeyBinding Gesture="Meta+Z" Command="{Binding ResetCartCommand}" />
        <KeyBinding Gesture="Control+Z" Command="{Binding ResetCartCommand}" />
    </Window.KeyBindings>

    <Grid>
        <Grid IsVisible="{Binding IsLoginScreen}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="460">
            <Border CornerRadius="22"
                    Padding="24"
                    BorderBrush="#D8E0EA"
                    BorderThickness="1"
                    Background="White">
                <StackPanel Spacing="14">
                    <Border IsVisible="{Binding IsOfflineMode}"
                            CornerRadius="10"
                            Padding="10,6"
                            Background="#FEF3C7"
                            Margin="0,0,0,6">
                        <TextBlock Text="Оффлайн режим: вход возможен только по уже сохраненной сессии"
                                   Foreground="#92400E" />
                    </Border>
                    <Border IsVisible="{Binding HasErrorMessage}"
                            CornerRadius="10"
                            Padding="10,6"
                            Background="#FFE4E6">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#BE123C" />
                    </Border>
                    <Border IsVisible="{Binding HasStatusMessage}"
                            CornerRadius="10"
                            Padding="10,6"
                            Background="#DCFCE7">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#166534" />
                    </Border>
                    <TextBlock Text="Вход в систему"
                               FontWeight="SemiBold"
                               FontSize="30"
                               Foreground="#0F172A" />
                    <TextBlock Text="Введите номер телефона и пароль"
                               Foreground="#475569"
                               Margin="0,0,0,10" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="Номер телефона" Foreground="#334155" />
                        <TextBox Text="{Binding Phone}"
                                 Watermark="Введите номер телефона"
                                 Height="42" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Пароль" Foreground="#334155" />
                        <TextBox Text="{Binding Password}"
                                 PasswordChar="*"
                                 Watermark="Введите пароль"
                                 Height="42" />
                    </StackPanel>

                    <Button Content="Войти"
                            Height="44"
                            Background="#10B981"
                            Foreground="White"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Stretch"
                            Command="{Binding LoginCommand}" />

                    <TextBlock Text="{Binding ApiBaseUrl, StringFormat=API: {0}}"
                               Foreground="#64748B"
                               FontSize="12" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsShiftScreen}"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Width="540">
            <Border CornerRadius="24"
                    Padding="24"
                    BorderBrush="#D8E0EA"
                    BorderThickness="1"
                    Background="White">
                <StackPanel Spacing="14">
                    <Border IsVisible="{Binding IsOfflineMode}"
                            CornerRadius="10"
                            Padding="10,6"
                            Background="#FEF3C7"
                            Margin="0,0,0,6">
                        <TextBlock Text="Оффлайн режим: открытие/закрытие смены синхронизируется автоматически"
                                   Foreground="#92400E" />
                    </Border>
                    <Border IsVisible="{Binding HasErrorMessage}"
                            CornerRadius="10"
                            Padding="10,6"
                            Background="#FFE4E6">
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="#BE123C" />
                    </Border>
                    <Border IsVisible="{Binding HasStatusMessage}"
                            CornerRadius="10"
                            Padding="10,6"
                            Background="#DCFCE7">
                        <TextBlock Text="{Binding StatusMessage}" Foreground="#166534" />
                    </Border>
                    <TextBlock Text="Создание смены"
                               FontWeight="SemiBold"
                               FontSize="30"
                               Foreground="#0F172A" />
                    <TextBlock Text="Смена не открыта. Укажите стартовую сумму и начните работу."
                               Foreground="#475569"
                               TextWrapping="Wrap" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="Начальная наличность" Foreground="#334155" />
                        <TextBox Text="{Binding InitialCashInput}"
                                 Watermark="Введите сумму"
                                 Height="42" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10" Margin="0,8,0,0">
                        <Button Grid.Column="0"
                                Content="Открыть смену"
                                Height="44"
                                Background="#10B981"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                FontWeight="SemiBold"
                                Command="{Binding OpenShiftCommand}" />
                        <Button Grid.Column="1"
                                Content="Выйти (ctrl+shift+q)"
                                Height="44"
                                Background="#F43F5E"
                                Foreground="White"
                                HorizontalAlignment="Stretch"
                                FontWeight="SemiBold"
                                Command="{Binding LogoutCommand}" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Grid IsVisible="{Binding IsPosScreen}"
              RowDefinitions="Auto,*"
              Margin="14">
            <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,8">
                <Border IsVisible="{Binding IsOfflineMode}"
                        CornerRadius="10"
                        Padding="12,8"
                        Background="#FEF3C7">
                    <TextBlock Text="{Binding ConnectionStatusLabel, StringFormat=Режим: {0}. Данные будут синхронизированы после восстановления сети}"
                               Foreground="#92400E" />
                </Border>
                <Border IsVisible="{Binding HasErrorMessage}"
                        CornerRadius="10"
                        Padding="12,8"
                        Background="#FFE4E6">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="#BE123C" />
                </Border>
                <Border IsVisible="{Binding HasStatusMessage}"
                        CornerRadius="10"
                        Padding="12,8"
                        Background="#DCFCE7">
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="#166534" />
                </Border>
            </StackPanel>

            <Grid Grid.Row="1"
                  ColumnDefinitions="360,*,500"
                  ColumnSpacing="14">
                <Border Grid.Column="0"
                        CornerRadius="20"
                        Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1"
                        Padding="14">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <StackPanel Spacing="2">
                            <TextBlock Text="TexHub POS"
                                       Foreground="#64748B"
                                       FontSize="12" />
                            <TextBlock Text="Кассовая панель"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <TextBlock Text="{Binding ShiftNumberLabel}"
                                       Foreground="#334155"
                                       Margin="0,2,0,0" />
                            <TextBlock Text="{Binding UserNameLabel, StringFormat=Кассир: {0}}"
                                       Foreground="#334155" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,14,0,14" Spacing="8">
                            <Button Background="#10B981"
                                    Foreground="White"
                                    Height="44"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding ToggleCloseShiftDialogCommand}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <svg:Svg Path="/Assets/icons/solar/power-linear.svg"
                                             Width="18"
                                             Height="18"
                                             VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,0,0"
                                               Text="Закрыть смену (ctrl+shift+s)"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button Background="#F59E0B"
                                    Foreground="White"
                                    Height="44"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding TogglePayDebtDialogCommand}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <svg:Svg Path="/Assets/icons/solar/hand-money-linear.svg"
                                             Width="18"
                                             Height="18"
                                             VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,0,0"
                                               Text="Погасить долг (ctrl+shift+p)"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button Background="#06B6D4"
                                    Foreground="White"
                                    Height="44"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding ToggleAddProductDialogCommand}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <svg:Svg Path="/Assets/icons/solar/box-linear.svg"
                                             Width="18"
                                             Height="18"
                                             VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,0,0"
                                               Text="Добавить товар (ctrl+shift+a)"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button Background="#F97316"
                                    Foreground="White"
                                    Height="44"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding ToggleAddExpenseDialogCommand}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <svg:Svg Path="/Assets/icons/solar/bill-list-linear.svg"
                                             Width="18"
                                             Height="18"
                                             VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,0,0"
                                               Text="Добавить расход (ctrl+shift+e)"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button Background="#94A3B8"
                                    Foreground="White"
                                    Height="44"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding RefreshAllCommand}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <svg:Svg Path="/Assets/icons/solar/refresh-linear.svg"
                                             Width="18"
                                             Height="18"
                                             VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,0,0"
                                               Text="Обновить (ctrl+r)"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Button>

                            <Button Background="#F43F5E"
                                    Foreground="White"
                                    Height="44"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Command="{Binding LogoutCommand}">
                                <Grid ColumnDefinitions="Auto,*">
                                    <svg:Svg Path="/Assets/icons/solar/logout-2-linear.svg"
                                             Width="18"
                                             Height="18"
                                             VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Margin="10,0,0,0"
                                               Text="Выйти из аккаунта (ctrl+shift+q)"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Button>
                        </StackPanel>

                        <Border Grid.Row="2"
                                CornerRadius="14"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Background="#F8FAFC"
                                Padding="10">
                            <Grid RowDefinitions="Auto,*">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                    <TextBlock Text="Список корзин"
                                               FontWeight="SemiBold"
                                               Foreground="#0F172A" />
                                    <Border CornerRadius="10"
                                            Background="#E2E8F0"
                                            Padding="6,2"
                                            HorizontalAlignment="Right"
                                            Margin="8,0,0,0">
                                        <TextBlock Text="{Binding CartCount}" Foreground="#475569" />
                                    </Border>
                                </StackPanel>
                                <ScrollViewer Grid.Row="1"
                                              Margin="0,8,0,0"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding Carts}"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Top">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,0,8"
                                                        Height="40"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Content="{Binding Id, StringFormat=Корзина #{0}}"
                                                        Command="{Binding DataContext.SelectCartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding .}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        CornerRadius="20"
                        Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1"
                        Padding="14">
                    <Grid RowDefinitions="Auto,Auto,*">
                        <TextBlock Text="Сканирование"
                                   Foreground="#64748B"
                                   FontSize="12" />
                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,6,0,10">
                            <TextBox Grid.Column="0"
                                     x:Name="BarcodeInputTextBox"
                                     Text="{Binding BarcodeInput}"
                                     Watermark="Сканируй штрих-код"
                                     Height="42"
                                     KeyDown="BarcodeInputTextBox_OnKeyDown" />
                            <Button Grid.Column="1"
                                    Content="Добавить"
                                    Height="42"
                                    Background="#06B6D4"
                                    Foreground="White"
                                    Command="{Binding AddByBarcodeCommand}" />
                        </Grid>

                        <ScrollViewer Grid.Row="2">
                            <ItemsControl ItemsSource="{Binding Products}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                Background="#F8FAFC"
                                                Margin="0,0,0,8"
                                                Padding="10">
                                            <Grid ColumnDefinitions="*,Auto,Auto"
                                                  ColumnSpacing="12">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#0F172A"
                                                               TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{Binding Quantity, StringFormat=Остаток: {0}}"
                                                               Foreground="#64748B"
                                                               FontSize="12" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding SellingPrice, StringFormat={}{0:0.##} c}"
                                                           FontWeight="Bold"
                                                           Foreground="#B45309" />
                                                <Button Grid.Column="2"
                                                        Content="Добавить"
                                                        Height="34"
                                                        Background="#06B6D4"
                                                        Foreground="White"
                                                        Command="{Binding DataContext.AddProductToCartCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding .}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        CornerRadius="20"
                        Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1"
                        Padding="14">
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel>
                                <TextBlock Text="Активная смена"
                                           Foreground="#64748B"
                                           FontSize="12" />
                                <TextBlock Text="{Binding ShiftNumberLabel}"
                                           FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="#0F172A" />
                            </StackPanel>
                            <Border Grid.Column="1"
                                    CornerRadius="12"
                                    Padding="10,6"
                                    Background="#DCFCE7"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding SelectedCartItemsCount, StringFormat=Товаров: {0}}"
                                           Foreground="#166534" />
                            </Border>
                        </Grid>

                        <ScrollViewer Grid.Row="1" Margin="0,10,0,10">
                            <ItemsControl ItemsSource="{Binding CartItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12"
                                                BorderBrush="#E2E8F0"
                                                BorderThickness="1"
                                                Margin="0,0,0,8"
                                                Background="#F8FAFC"
                                                Padding="8">
                                            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                                                <TextBlock Text="{Binding ProductName}"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="#0F172A"
                                                           TextTrimming="CharacterEllipsis" />
                                                <Grid Grid.Column="1" ColumnDefinitions="Auto,Auto,Auto" ColumnSpacing="6" VerticalAlignment="Center">
                                                    <Button Grid.Column="0"
                                                            Width="30"
                                                            Height="30"
                                                            Background="#E2E8F0"
                                                            BorderBrush="#CBD5E1"
                                                            BorderThickness="1"
                                                            Command="{Binding DataContext.DecrementItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding .}">
                                                        <svg:Svg Path="/Assets/icons/solar/minus-circle-linear.svg"
                                                                 Width="16"
                                                                 Height="16"
                                                                 VerticalAlignment="Center"
                                                                 HorizontalAlignment="Center" />
                                                    </Button>
                                                    <TextBlock Grid.Column="1"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Center"
                                                               Text="{Binding Quantity}"
                                                               FontWeight="SemiBold" />
                                                    <Button Grid.Column="2"
                                                            Width="30"
                                                            Height="30"
                                                            Background="#E2E8F0"
                                                            BorderBrush="#CBD5E1"
                                                            BorderThickness="1"
                                                            Command="{Binding DataContext.IncrementItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding .}">
                                                        <svg:Svg Path="/Assets/icons/solar/add-circle-linear.svg"
                                                                 Width="16"
                                                                 Height="16"
                                                                 VerticalAlignment="Center"
                                                                 HorizontalAlignment="Center" />
                                                    </Button>
                                                </Grid>
                                                <TextBlock Grid.Column="2"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding LineSubtotal, StringFormat={}{0:0.##} c}"
                                                           FontWeight="Bold"
                                                           Foreground="#B45309" />
                                                <Button Grid.Column="3"
                                                        Width="32"
                                                        Height="32"
                                                        Background="#DBEAFE"
                                                        BorderBrush="#BFDBFE"
                                                        BorderThickness="1"
                                                        Command="{Binding DataContext.OpenItemDiscountDialogCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding .}">
                                                    <svg:Svg Path="/Assets/icons/solar/tag-price-linear.svg"
                                                             Width="16"
                                                             Height="16"
                                                             VerticalAlignment="Center"
                                                             HorizontalAlignment="Center" />
                                                </Button>
                                                <Button Grid.Column="4"
                                                        Width="32"
                                                        Height="32"
                                                        Background="#FFE4E6"
                                                        BorderBrush="#FECDD3"
                                                        BorderThickness="1"
                                                        Foreground="#BE123C"
                                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding .}">
                                                    <svg:Svg Path="/Assets/icons/solar/trash-bin-2-linear.svg"
                                                             Width="16"
                                                             Height="16"
                                                             VerticalAlignment="Center"
                                                             HorizontalAlignment="Center" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Row="2"
                                CornerRadius="14"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Background="#F8FAFC"
                                Padding="10">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Подытог" Foreground="#64748B" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Subtotal, StringFormat={}{0:0.##} c}"
                                               FontWeight="SemiBold" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Скидка" Foreground="#64748B" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DiscountTotal, StringFormat={}{0:0.##} c}"
                                               FontWeight="SemiBold"
                                               Foreground="#15803D" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Итог" Foreground="#64748B" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Total, StringFormat={}{0:0.##} c}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Foreground="#B45309" />
                                </Grid>

                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="8"
                                      Margin="0,8,0,0"
                                      HorizontalAlignment="Stretch">
                                    <Button Grid.Column="0"
                                            Background="#F43F5E"
                                            Foreground="White"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding ToggleDiscountDialogCommand}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <svg:Svg Path="/Assets/icons/solar/sale-linear.svg"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       Text="Скидка (ctrl+m)"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Background="#06B6D4"
                                            Foreground="White"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding ToggleCheckoutDialogCommand}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <svg:Svg Path="/Assets/icons/solar/check-square-linear.svg"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       Text="Оформить (ctrl+enter)"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                </Grid>
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="8"
                                      HorizontalAlignment="Stretch">
                                    <Button Grid.Column="0"
                                            Background="#CBD5E1"
                                            Foreground="#0F172A"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding HoldCartCommand}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <svg:Svg Path="/Assets/icons/solar/copy-linear.svg"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       Text="Держать (ctrl+x)"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Background="#F43F5E"
                                            Foreground="White"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding ResetCartCommand}">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <svg:Svg Path="/Assets/icons/solar/restart-linear.svg"
                                                     Width="18"
                                                     Height="18"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       Text="Сбросить (ctrl+z)"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border IsVisible="{Binding IsDiscountDialogOpen}"
                Background="#880F172A">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="440">
                <Border Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18">
                    <StackPanel Spacing="12"
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="Скидка на корзину" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="Выберите тип: fixed или percent"
                                   Foreground="#64748B"
                                   FontSize="12" />
                        <ComboBox ItemsSource="{Binding DiscountTypes}"
                                  SelectedItem="{Binding DiscountType}"
                                  HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding DiscountValueInput}"
                                 Watermark="Введите сумму или процент"
                                 HorizontalAlignment="Stretch" />
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10"
                              HorizontalAlignment="Stretch">
                            <Button Grid.Column="0"
                                    Content="Применить (ctrl+shift+m)"
                                    Background="#10B981"
                                    Foreground="White"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ApplyDiscountCommand}" />
                            <Button Grid.Column="1"
                                    Content="Закрыть (esc)"
                                    Background="#E2E8F0"
                                    Foreground="#0F172A"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ToggleDiscountDialogCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsItemDiscountDialogOpen}"
                Background="#880F172A">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="440">
                <Border Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="18">
                    <StackPanel Spacing="12"
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="Скидка на товар" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SelectedDiscountItem.ProductName}"
                                   Foreground="#334155"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="Выберите тип: fixed или percent"
                                   Foreground="#64748B"
                                   FontSize="12" />
                        <ComboBox ItemsSource="{Binding ItemDiscountTypes}"
                                  SelectedItem="{Binding ItemDiscountType}"
                                  HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding ItemDiscountValueInput}"
                                 Watermark="Введите сумму или процент"
                                 HorizontalAlignment="Stretch" />
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10"
                              HorizontalAlignment="Stretch">
                            <Button Grid.Column="0"
                                    Content="Применить (ctrl+shift+d)"
                                    Background="#10B981"
                                    Foreground="White"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ApplyItemDiscountCommand}" />
                            <Button Grid.Column="1"
                                    Content="Закрыть (esc)"
                                    Background="#E2E8F0"
                                    Foreground="#0F172A"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ToggleItemDiscountDialogCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsCheckoutDialogOpen}"
                Background="#880F172A">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="520">
                <Border Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16">
                    <StackPanel Spacing="10"
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="Оформить заказ" FontSize="22" FontWeight="SemiBold" />
                        <ComboBox ItemsSource="{Binding PaymentMethods}"
                                  SelectedItem="{Binding PaymentMethod}"
                                  HorizontalAlignment="Stretch" />

                        <TextBox IsVisible="{Binding IsDebtPayment}"
                                 Text="{Binding CustomerName}"
                                 Watermark="Имя клиента" />
                        <TextBox IsVisible="{Binding IsDebtPayment}"
                                 Text="{Binding CustomerPhone}"
                                 Watermark="Телефон клиента" />

                        <TextBox Text="{Binding CashInput}" Watermark="Полученная сумма" />
                        <TextBox Text="{Binding OrderNote}" Watermark="Комментарий (необязательно)" />

                        <Border BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10"
                                Background="#F8FAFC">
                            <StackPanel Spacing="6">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Подытог" Foreground="#64748B" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Subtotal, StringFormat={}{0:0.##} c}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Скидка" Foreground="#64748B" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DiscountTotal, StringFormat={}{0:0.##} c}" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Итог" Foreground="#64748B" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Total, StringFormat={}{0:0.##} c}"
                                               FontWeight="Bold" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Сдача" Foreground="#64748B" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ChangeAmount, StringFormat={}{0:0.##} c}"
                                               FontWeight="Bold"
                                               Foreground="#0369A1" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8"
                              HorizontalAlignment="Stretch">
                            <Button Grid.Column="0"
                                    Content="Оформить (ctrl+shift+enter)"
                                    Background="#10B981"
                                    Foreground="White"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding CheckoutCommand}" />
                            <Button Grid.Column="1"
                                    Content="Закрыть (esc)"
                                    Background="#E2E8F0"
                                    Foreground="#0F172A"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ToggleCheckoutDialogCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsCloseShiftDialogOpen}"
                Background="#880F172A">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="420">
                <Border Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Закрыть смену" FontSize="22" FontWeight="SemiBold" />
                        <TextBox Text="{Binding FinalCashInput}" Watermark="Наличными в кассе" />
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                            <Button Grid.Column="0"
                                    Content="Закрыть смену"
                                    Background="#10B981"
                                    Foreground="White"
                                    Command="{Binding CloseShiftCommand}" />
                            <Button Grid.Column="1"
                                    Content="Отмена"
                                    Background="#E2E8F0"
                                    Foreground="#0F172A"
                                    Command="{Binding ToggleCloseShiftDialogCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsPayDebtDialogOpen}"
                Background="#880F172A">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">
                <Border Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16">
                    <StackPanel Spacing="10"
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="Погасить долг" FontSize="22" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="8"
                              HorizontalAlignment="Stretch">
                            <TextBox Grid.Column="0"
                                     Text="{Binding DebtPhoneInput}"
                                     Watermark="Телефон клиента"
                                     HorizontalAlignment="Stretch" />
                            <Button Grid.Column="1"
                                    Content="Найти"
                                    Background="#CBD5E1"
                                    Foreground="#0F172A"
                                    Command="{Binding FindDebtCustomerCommand}" />
                        </Grid>
                        <TextBox Text="{Binding DebtCustomerNameInput}"
                                 Watermark="Имя клиента (необязательно)"
                                 HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding DebtTotalInput}"
                                 Watermark="Сумма погашения"
                                 HorizontalAlignment="Stretch" />
                        <Border IsVisible="{Binding HasDebtCustomerStatus}"
                                Background="#F1F5F9"
                                CornerRadius="10"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Padding="10,6">
                            <TextBlock Text="{Binding DebtCustomerStatus}"
                                       Foreground="#334155" />
                        </Border>
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8"
                              HorizontalAlignment="Stretch">
                            <Button Grid.Column="0"
                                    Content="Погасить"
                                    Background="#10B981"
                                    Foreground="White"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding PayDebtCommand}" />
                            <Button Grid.Column="1"
                                    Content="Закрыть (esc)"
                                    Background="#E2E8F0"
                                    Foreground="#0F172A"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding TogglePayDebtDialogCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsAddProductDialogOpen}"
                Background="#880F172A">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="520">
                <Border Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16">
                    <StackPanel Spacing="10"
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="Добавить товар" FontSize="22" FontWeight="SemiBold" />
                        <TextBox Text="{Binding NewProductSkuInput}"
                                 Watermark="Артикул (SKU)"
                                 HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding NewProductQuantityInput}"
                                 Watermark="Количество"
                                 HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding NewProductNameInput}"
                                 Watermark="Название (для нового товара)"
                                 HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding NewProductPriceInput}"
                                 Watermark="Цена продажи (для нового товара)"
                                 HorizontalAlignment="Stretch" />
                        <ComboBox ItemsSource="{Binding ProductStatuses}"
                                  SelectedItem="{Binding NewProductStatus}"
                                  HorizontalAlignment="Stretch" />
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8"
                              HorizontalAlignment="Stretch">
                            <Button Grid.Column="0"
                                    Content="Сохранить"
                                    Background="#10B981"
                                    Foreground="White"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding SaveProductCommand}" />
                            <Button Grid.Column="1"
                                    Content="Закрыть (esc)"
                                    Background="#E2E8F0"
                                    Foreground="#0F172A"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ToggleAddProductDialogCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsAddExpenseDialogOpen}"
                Background="#880F172A">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">
                <Border Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16">
                    <StackPanel Spacing="10"
                                HorizontalAlignment="Stretch">
                        <TextBlock Text="Добавить расход" FontSize="22" FontWeight="SemiBold" />
                        <TextBox Text="{Binding ExpenseTotalInput}"
                                 Watermark="Сумма расхода"
                                 HorizontalAlignment="Stretch" />
                        <TextBox Text="{Binding ExpenseDescriptionInput}"
                                 Watermark="Комментарий/описание"
                                 HorizontalAlignment="Stretch" />
                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="8"
                              HorizontalAlignment="Stretch">
                            <Button Grid.Column="0"
                                    Content="Сохранить"
                                    Background="#10B981"
                                    Foreground="White"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding AddExpenseCommand}" />
                            <Button Grid.Column="1"
                                    Content="Закрыть (esc)"
                                    Background="#E2E8F0"
                                    Foreground="#0F172A"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding ToggleAddExpenseDialogCommand}" />
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border IsVisible="{Binding IsBusy}"
                Background="#66F1F5F9">
            <Grid HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Width="220">
                <Border CornerRadius="16"
                        Padding="14"
                        Background="White"
                        BorderBrush="#D8E0EA"
                        BorderThickness="1">
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True" Width="180" />
                        <TextBlock Text="Загрузка..." HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
